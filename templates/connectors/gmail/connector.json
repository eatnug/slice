{
  "id": "gmail",
  "aliases": ["google", "google-workspace", "gcal", "calendar"],
  "label": "Gmail + Google Calendar",
  "description": "Read-only Gmail and Google Calendar MCP connector.",
  "pluginPath": ".slice/plugins/google-workspace",
  "files": "files",
  "prompts": {
    "install": "prompts/install.md",
    "use": "prompts/use.md"
  },
  "authCommand": "uv run google-workspace-auth",
  "serverName": "google_workspace",
  "transport": "stdio",
  "runtime": {
    "command": "uv",
    "args": [
      "--directory",
      "${pluginDir}/tools/google_workspace_mcp",
      "run",
      "google-workspace-mcp"
    ],
    "env": {
      "GOOGLE_WORKSPACE_MCP_TZ": "Asia/Seoul"
    }
  },
  "tools": [
    "google_workspace_auth_status",
    "google_calendar_list_calendars",
    "google_calendar_list_events",
    "gmail_search_messages",
    "gmail_get_message"
  ],
  "policies": {
    "codex": {
      "approvalMode": "approve"
    },
    "gemini": {
      "timeout": 30000,
      "trust": false
    },
    "claude": {
      "projectScoped": true
    }
  }
}
