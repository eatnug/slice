{
  "mcpServers": {
    "google_workspace": {
      "type": "stdio",
      "command": "/path/to/uv",
      "args": [
        "--directory",
        "/path/to/repo/.slice/plugins/google-workspace/tools/google_workspace_mcp",
        "run",
        "google-workspace-mcp"
      ],
      "env": {
        "GOOGLE_WORKSPACE_MCP_TZ": "Asia/Seoul"
      }
    }
  }
}
